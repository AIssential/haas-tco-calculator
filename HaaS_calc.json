      ""total_elec_ep"": ""(total_heat + heat_losses) / scop_ep"",
      ""total_elec_hp"": ""total_heat / scop_hp""
    },
    ""pv_lcoe"": {
      ""annual_generation"": ""pv_power_kw * full_load_hours"",
      ""degradation"": ""each year: prev_year * (1 - degradation_rate)"",
      ""pv_cost_ep"": ""pv_power_kw * pv_cost_per_kw (no inverter)"",
      ""pv_cost_hp"": ""pv_power_kw * pv_cost_per_kw + inverter_cost"",
      ""lcoe"": ""(pv_total_cost + sum_discounted_opex) / sum_discounted_generation"",
      ""note"": ""Discount over pv_"
"lifetime years using discount_rate_pv""
    },
    ""blended_electricity_price"": {
      ""ep_working_price"": ""self_consumption_ep * pv_lcoe_ep + (1 - self_consumption_ep) * electricity_price_ep"",
      ""hp_working_price"": ""self_consumption_hp * pv_lcoe_hp + (1 - self_consumption_hp) * electricity_price_hp""
    },
    ""subsidy"": {
      ""elephant_one"": ""(sum_installation + heating_calc + radiator_piping + ep_box*0.7) * subsidy_rate"",
      ""standard_hp"": ""(sum_installation + heating_calc + radiator_piping + dhw_buffer + hp_unit) * subsidy_rate"",
      ""gas_boiler"": ""0""
    },
    ""annuity_factor"": ""(interest_rate * (1+interest_rate)^lifetime) / ((1+interest_rate)^lifetime - 1)"",
    ""lcoh"": {
      ""lcoh_capex"": ""((sum_capex + sum_installation - subsidy) / lifetime) / total_heat"",
      ""lcoh"
"_opex"": ""sum_opex / total_heat"",
      ""lcoh_energy_ep"": ""(base_price + working_price_ep * total_elec_ep) / total_heat"",
      ""lcoh_energy_hp"": ""(base_price + working_price_hp * total_elec_hp) / total_heat"",
      ""lcoh_energy_gas"": ""(gas_base_price + gas_price * total_heat / boiler_efficiency) / total_heat"",
      ""lcoh_total"": ""lcoh_capex + lcoh_opex + lcoh_energy"",
      ""annuity_payment"": ""(sum_capex + sum_installation) * (1 - equity_share) * annuity_factor"",
      ""opportunity_cost"": ""(sum_capex + sum_installation) * wacc""
    }
